# LiveKit Configuration (local or cloud)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Local STT Configuration (Whisper)
WHISPER_MODEL=base  # tiny, base, small, medium, large
WHISPER_DEVICE=cpu  # cpu or cuda

# Local TTS Configuration (Coqui)
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
TTS_DEVICE=cpu  # cpu or cuda

# Local LLM Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Alternative: llama3.1:70b, mistral, phi3

# VAD Configuration
VAD_MIN_SPEECH_DURATION=250
VAD_SILENCE_DURATION=700
VAD_ENERGY_THRESHOLD=0.5

# Optional: Use OpenAI-compatible endpoints for local LLMs
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
