# LiveKit Configuration
LIVEKIT_URL=wss://your-instance.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Speech-to-Text (Deepgram)
DEEPGRAM_API_KEY=your_deepgram_key_here

# Text-to-Speech (ElevenLabs)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# LLM Configuration
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4o

# Google Calendar Configuration
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials/google-calendar-service-account.json
GOOGLE_CALENDAR_ID=primary

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ENABLE_SMS=true

# Call Configuration
ENABLE_VOICEMAIL_DETECTION=true
VOICEMAIL_MESSAGE="Hi, this is the scheduling assistant. Please call us back or check your text messages."
MAX_CALL_DURATION_SECONDS=300
CALL_TIMEOUT_SECONDS=30

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your-secret-key-change-in-production

# RAG Configuration - Phase 4
VECTOR_DB_TYPE=chromadb
VECTOR_DB_PATH=./data/chroma
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.7

# Fallback Configuration - Phase 4
ENABLE_TIERED_FALLBACK=true
LOW_CONFIDENCE_THRESHOLD=0.6
MAX_RETRY_ATTEMPTS=3
CALLBACK_QUEUE_ENABLED=true
ESCALATION_PHONE_NUMBER=+1234567890

# Dispatcher Configuration - Phase 4
DISPATCHER_AVAILABLE_HOURS_START=8
DISPATCHER_AVAILABLE_HOURS_END=18
WARM_TRANSFER_ENABLED=true

# Database
DATABASE_URL=sqlite:///./data/appointments.db

# Langfuse (Phase 5+)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
